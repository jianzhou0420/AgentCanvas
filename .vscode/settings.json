{
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",
    "python.analysis.extraPaths": [
        "third_party/habitat-lab",
        "third_party/VLN-CE"
    ],

    // Format-on-save is OFF globally; per-language blocks below opt in.
    // This prevents random extensions from stealing format-on-save for
    // file types we don't want auto-formatted (Markdown, YAML, shell).
    "editor.formatOnSave": false,

    // Python: ruff for both linting and formatting.
    // Reads config from ruff.toml at the repo root.
    // Requires extension: charliermarsh.ruff
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },

    // Disable the legacy ms-python formatter so it can't fight ruff.
    "python.formatting.provider": "none",

    // TypeScript / React / JSON / CSS: prettier.
    // Requires extension: esbenp.prettier-vscode
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // Use ruff's native language server (faster, supersedes ruff-lsp).
    "ruff.nativeServer": "on",
    "liveServer.settings.port": 5505,

    // third_party/ has 30+ submodules — exclude from the file watcher so
    // VSCode doesn't blow past the inotify limit. Reload window after edit.
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "third_party/**": true,
        "**/third_party/**": true
    },

    // zz_just_for_refer/ is 2.7 GB of read-only reference repos (AgentSquare,
    // NavGPT, OpenClaw, etc.) — hide from the explorer, search index, and
    // Pylance so they stop consuming inotify instances / RAM. Open those
    // repos in a separate VSCode window when you need to read them.
    "files.exclude": {
        "third_party/zz_just_for_refer": true
    },
    "search.exclude": {
        "third_party/zz_just_for_refer": true,
        "third_party/**": true
    },
    "python.analysis.exclude": [
        "**/third_party/zz_just_for_refer/**"
    ],

    // Port auto-forward: only scan terminal output (not /proc/net/tcp) so
    // experiment/server-mode listeners don't flood the Ports panel.
    "remote.autoForwardPortsSource": "output",
    "remote.portsAttributes": {
        "8000":      { "label": "agentcanvas-backend", "onAutoForward": "notify" },
        "5173":      { "label": "vite",                "onAutoForward": "notify" },
        "5503":      { "label": "live-server",         "onAutoForward": "silent" },
        "8765-8769": { "label": "experiment-pool",     "onAutoForward": "ignore" },
        "6006":      { "label": "tensorboard",         "onAutoForward": "silent" }
    }
}
