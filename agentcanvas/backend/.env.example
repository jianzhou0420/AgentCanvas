# LLM Configuration — env var fallback when no profile is active
# Primary names (preferred):
AGENTCANVAS_API_KEY=
AGENTCANVAS_MODEL=gpt-4o
AGENTCANVAS_BASE_URL=
AGENTCANVAS_API_TYPE=openai

# Legacy aliases (still supported, checked if AGENTCANVAS_* are unset):
# VLM_API_KEY=
# VLM_MODEL=gpt-4o
# VLM_BASE_URL=
# VLM_API_TYPE=

# Operational settings (ephemeral overrides available via PUT /api/config/)
DEBUG=true
VLM_MAX_STEPS=20
SLAM_BACKEND=mock
WS_HEARTBEAT_SEC=15
