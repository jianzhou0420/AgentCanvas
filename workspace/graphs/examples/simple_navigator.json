      "target": "history_log",
      "sourceHandle": "value",
      "targetHandle": "entry"
    },
    {
      "id": "e_historylog_to_iterout",
      "source": "history_log",
      "target": "iter_out",
      "sourceHandle": "history",
      "targetHandle": "history"
    },
    {
      "id": "e_step_info_to_loopobs",
      "source": "env_step",
      "target": "loop_obs",
      "sourceHandle": "info",
      "targetHandle": "trigger"
    },
    {
      "id": "e_loopobs_rgb_to_iterout",
      "source": "loop_obs",
      "target": "iter_out",
      "sourceHandle": "rgb",
      "targetHandle": "rgb"
    },
    {
      "id": "e_loopobs_pose_to_iterout",
      "source": "loop_obs",
      "target": "iter_out",
      "sourceHandle": "pose",
      "targetHandle": "pose"
    },
    {
      "id": "e_loopobs_rgb_to_viewer",
      "source": "loop_obs",
      "target": "obs_viewer",
      "sourceHandle": "rgb",
      "targetHandle": "rgb"
    },
    {
      "id": "e_step_terminated_to_termination__stop",
      "source": "env_step",
      "target": "iter_out",
      "sourceHandle": "terminated",
      "targetHandle": "stop"
    },
    {
      "id": "e_evaluate_to_metricsviewer",
      "source": "evaluate",
      "target": "metrics_viewer",
      "sourceHandle": "metrics",
      "targetHandle": "metrics"
    },
    {
      "id": "e_evaluate_to_graphout",
      "source": "evaluate",
      "target": "output_port__metrics",
      "sourceHandle": "metrics",
      "targetHandle": "value"
    },
    {
      "id": "e_iter_out_finalstop_to_evaluate",
      "source": "iter_out",
      "sourceHandle": "final_stop",
      "target": "evaluate",
      "targetHandle": "trigger"
    }
  ]
}
