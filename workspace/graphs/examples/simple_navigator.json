      "target": "planner_llm",
      "sourceHandle": "iterout_history",
      "targetHandle": "history"
    },
    {
      "id": "e_llm_to_parse",
      "source": "planner_llm",
      "target": "parse_action",
      "sourceHandle": "response",
      "targetHandle": "text"
    },
    {
      "id": "e_llm_to_scroll",
      "source": "planner_llm",
      "target": "reasoning_scroll",
      "sourceHandle": "response",
      "targetHandle": "text"
    },
    {
      "id": "e_parse_index_to_step",
