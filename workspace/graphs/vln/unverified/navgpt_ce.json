      "position": {
        "x": 1680,
        "y": 600
      },
      "config": {
        "n_views": 12,
        "representation": "composite"
      }
    },
    {
      "id": "history_update_llm",
      "type": "llmCall",
      "label": "History Update LLM",
      "position": {
        "x": 1400,
        "y": 440
      },
      "config": {
        "temperature": 0.0,
        "max_tokens": 300,
        "mode": "single_turn",
        "write_to_state": "history",
        "template": "You are tracking a navigation agent's step-by-step history.\n\nPrevious history:\n{history}\n\nAction just taken: {action}\nNew panoramic observation at this viewpoint:\n{summary}\n\nAppend one concise line summarizing this step to the history.\n\nUpdated history:"
      }
    },
