{
  "name": "VGGT-SLAM 2.0 on TUM — open-set object query variant",
  "description": "vggt_slam_tum with the open-set path live: run_os=true at reset (PE-CLIP embeddings computed during tracking), and after finalize a query_object node retrieves the best keyframe for a text prompt (default 'keyboard'), segments it with SAM 3 (lazy-loaded), and lifts each mask to world-frame points + a PCA OBB. Head-truncated to 200 frames — the query only needs a built map, not a full sequence. Scalar outputs: query score + num_instances alongside the SLAM metrics.",
  "presetId": "vggt_slam_tum_os",
  "step_budget": 5000,
  "nodes": [
    {
      "id": "tum_reset",
      "type": "env_tum__reset",
      "label": "TUM: Reset (arm sequence)",
      "position": {
        "x": 0,
        "y": 200
      },
      "config": {
        "max_frames": "200"
      }
    },
    {
      "id": "vggt_reset",
      "type": "model_vggt_slam__reset",
      "label": "VGGT-SLAM: Reset (episode start)",
      "position": {
        "x": 340,
        "y": 340
      },
      "config": {
        "submap_size": "16",
        "max_loops": "1",
        "min_disparity": "50",
        "conf_threshold": "25.0",
        "lc_thres": "0.95",
        "run_os": "true"
      }
    },
    {
      "id": "iterIn_tum",
      "type": "iterIn",
      "label": "Iter In",
      "position": {
        "x": 340,
        "y": 60
      },
      "config": {
        "version": 3,
        "pairedWith": "iterOut_tum",
        "initPorts": [
          {
            "name": "slam_ready",
            "wire_type": "ANY",
            "persist": true
          },
          {
            "name": "seq",
            "wire_type": "TEXT",
            "persist": false
          }
        ]
      }
    },
    {
      "id": "tum_step",
      "type": "env_tum__step_replay",
      "label": "TUM: Step (advance frame)",
      "position": {
        "x": 680,
        "y": 200
      },
      "config": {}
    },
    {
      "id": "tum_observe_loop",
      "type": "env_tum__observe_egocentric",
      "label": "TUM: Observe (egocentric)",
      "position": {
        "x": 1020,
        "y": 200
      },
      "config": {}
    },
    {
      "id": "vggt_track",
      "type": "model_vggt_slam__track",
      "label": "VGGT-SLAM: Track (per frame)",
      "position": {
        "x": 1360,
        "y": 200
      },
      "config": {}
    },
    {
      "id": "iterOut_tum",
      "type": "iterOut",
      "label": "Iter Out",
      "position": {
        "x": 1700,
        "y": 200
      },
      "config": {
        "pairedWith": "iterIn_tum",
        "ports": [
          {
            "name": "slam_ready",
            "wire_type": "ANY",
            "persist": true,
            "required": true
          },
          {
            "name": "seq",
            "wire_type": "TEXT",
            "persist": true,
            "required": true
          }
        ]
      }
    },
    {
      "id": "observationViewer",
      "type": "imageViewer",
      "label": "Observation (RGB)",
      "position": {
        "x": 620,
        "y": 700
      },
      "config": {
        "rows": 1,
        "cols": 1,
        "ports": [
          {
            "name": "rgb",
            "wire_type": "IMAGE"
          }
        ]
      }
    },
    {
      "id": "trajectoryViewer_slam",
      "type": "trajectoryViewer",
      "label": "SLAM Trajectory (submap bursts)",
      "position": {
        "x": 1200,
        "y": 700
      },
      "config": {
        "axes": "auto",
        "align": "on",
        "max_points": "5000"
      }
    },
    {
      "id": "vggt_finalize",
      "type": "model_vggt_slam__finalize",
      "label": "VGGT-SLAM: Finalize (flush tail submap)",
      "position": {
        "x": 2040,
        "y": 200
      },
      "config": {}
    },
    {
      "id": "vggt_get_traj",
      "type": "model_vggt_slam__get_trajectory",
      "label": "VGGT-SLAM: Get Trajectory",
      "position": {
        "x": 2380,
        "y": 80
      },
      "config": {}
    },
    {
      "id": "vggt_get_map",
      "type": "model_vggt_slam__get_map",
      "label": "VGGT-SLAM: Get Map (final .pcd)",
      "position": {
        "x": 2380,
        "y": 340
      },
      "config": {}
    },
    {
      "id": "vggt_eval",
      "type": "model_vggt_slam__eval_trajectory",
      "label": "VGGT-SLAM: Eval (ATE, evo -as)",
      "position": {
        "x": 2720,
        "y": 80
      },
      "config": {
        "align_scale": "true"
      }
    },
    {
      "id": "pointCloudViewer_slam",
      "type": "pointCloudViewer",
      "label": "Dense Map (3-D, final)",
      "position": {
        "x": 2720,
        "y": 700
      },
      "config": {
        "max_points": "30000",
        "point_size": "1.5"
      }
    },
    {
      "id": "output_port__slam_map_handle",
      "type": "graphOut",
      "label": "slam_map_handle",
      "position": {
        "x": 3060,
        "y": 340
      },
      "config": {
        "portName": "slam_map_handle",
        "wireType": "TEXT"
      }
    },
    {
      "id": "output_port__slam_eval_metrics",
      "type": "graphOut",
      "label": "metrics",
      "position": {
        "x": 3060,
        "y": 80
      },
      "config": {
        "portName": "metrics",
        "wireType": "METRICS"
      }
    },
    {
      "id": "output_port__num_poses",
      "type": "graphOut",
      "label": "num_poses",
      "position": {
        "x": 3060,
        "y": 200
      },
      "config": {
        "portName": "num_poses",
        "wireType": "ANY"
      }
    },
    {
      "id": "output_port__num_submaps",
