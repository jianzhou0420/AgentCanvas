        "wireType": "ANY"
      }
    },
    {
      "id": "output_port__num_loops",
      "type": "graphOut",
      "label": "num_loops",
      "position": {
        "x": 3060,
        "y": 600
      },
      "config": {
        "portName": "num_loops",
        "wireType": "ANY"
      }
    },
    {
      "id": "vggt_query",
      "type": "model_vggt_slam__query_object",
      "label": "VGGT-SLAM: Query 'keyboard'",
      "position": {
        "x": 2380,
        "y": 560
      },
      "config": {
        "sam3_conf": "0.50",
        "default_text": "keyboard"
      }
    },
    {
      "id": "output_port__query_score",
      "type": "graphOut",
      "label": "query_score",
      "position": {
        "x": 3060,
        "y": 560
      },
      "config": {
        "portName": "query_score",
        "wireType": "ANY"
      }
    },
    {
      "id": "output_port__query_instances",
      "type": "graphOut",
      "label": "query_instances",
      "position": {
        "x": 3060,
        "y": 660
      },
      "config": {
        "portName": "query_instances",
        "wireType": "ANY"
      }
    }
  ],
