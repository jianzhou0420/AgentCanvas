{
  "name": "pySLAM on TUM RGB-D (classic SLAM demo)",
  "description": "pySLAM's showcase: a classic RGB-D benchmark sequence (TUM fr3/long_office_household by default) streamed frame-by-frame into a live SLAM session — no simulator, no policy, no GPU. env_tum is a streaming-replay environment: tum_reset arms the placed sequence and emits its camera intrinsics; the loop advances one frame per step (tum_step_replay, a degenerate 'action'), observe_egocentric pulls that frame's RGB-D + ground-truth pose, and model_pyslam__track feeds it to the SLAM front-end (ORB2 features + DBOW3 loop closure, RGB-D metric depth). The loop stops when the sequence is exhausted (step_replay.terminated -> iterOut.stop). Depth is metric metres straight from the reader (TUM factor 5000), so pyslam_reset.depth_scale is 1.0. Intrinsics are the published freiburg3 pinhole, wired from tum_reset into pyslam_reset so the camera matches exactly. Three live views: observationViewer shows the raw RGB+depth; trajectoryViewer_slam grows the estimated camera path (blue) against the TUM ground truth (grey) top-down, live per frame — with align=on it SE3-fits the estimate onto the GT frame each update (standard ATE convention: GT is the reference, the estimate is aligned onto it), so the two overlay and the visible gap is the drift; pointCloudViewer_slam renders the sparse map in 3-D live, fed by an in-loop pyslam_get_map_live throttled to every 20 frames (stream_every=20) so the map densifies on screen without dumping the full cloud every step. A second, after-loop pyslam_get_map (stream_every=0) produces the final complete map handle for the slam_map_handle output. After the loop, get_trajectory + eval_trajectory report ATE/RPE against ground truth — a real SLAM-accuracy number, surfaced as slam_eval_metrics. This is the demo the VLN-CE probe could not be: pySLAM as the protagonist on its home turf. Runs on model_pyslam:cpu-fixed (no GPU). Fetch the sequence with workspace/nodesets/env/env_tum/download.sh.",
  "presetId": "pyslam_tum_slam",
  "step_budget": 5000,
  "nodes": [
    {
      "id": "tum_reset",
      "type": "env_tum__reset",
      "label": "TUM: Reset (arm sequence)",
      "position": {
        "x": 0,
        "y": 200
      },
      "config": {
        "max_frames": "400"
      }
    },
    {
      "id": "pyslam_reset",
      "type": "model_pyslam__reset",
      "label": "pySLAM: Reset (episode start)",
      "position": {
        "x": 340,
        "y": 340
      },
      "config": {
        "sensor_type": "rgbd",
        "feature_preset": "ORB2",
        "loop_preset": "DBOW3",
        "cam_hfov": "90",
        "depth_scale": "1.0"
      }
    },
    {
      "id": "iterIn_tum",
      "type": "iterIn",
      "label": "Iter In",
      "position": {
        "x": 340,
        "y": 60
      },
      "config": {
        "version": 3,
        "pairedWith": "iterOut_tum",
        "initPorts": [
          {
            "name": "slam_ready",
            "wire_type": "ANY",
            "persist": true
          }
        ]
      }
    },
    {
      "id": "tum_step",
      "type": "env_tum__step_replay",
      "label": "TUM: Step (advance frame)",
      "position": {
        "x": 680,
        "y": 200
      },
      "config": {}
    },
    {
      "id": "tum_observe_loop",
      "type": "env_tum__observe_egocentric",
      "label": "TUM: Observe (egocentric)",
      "position": {
        "x": 1020,
        "y": 200
      },
      "config": {}
    },
    {
      "id": "pyslam_track",
      "type": "model_pyslam__track",
      "label": "pySLAM: Track (per frame)",
      "position": {
        "x": 1360,
        "y": 200
      },
      "config": {}
    },
    {
      "id": "iterOut_tum",
      "type": "iterOut",
      "label": "Iter Out",
      "position": {
        "x": 1700,
        "y": 200
      },
      "config": {
        "pairedWith": "iterIn_tum",
        "ports": [
          {
            "name": "slam_ready",
            "wire_type": "ANY",
            "persist": true,
            "required": true
          }
        ]
      }
    },
    {
      "id": "observationViewer",
      "type": "imageViewer",
      "label": "Observation (RGB + Depth)",
      "position": {
        "x": 620,
        "y": 700
      },
      "config": {
        "rows": 1,
        "cols": 2,
        "ports": [
          {
            "name": "rgb",
            "wire_type": "IMAGE"
          },
          {
            "name": "depth",
            "wire_type": "DEPTH"
          }
        ]
      }
    },
    {
      "id": "trajectoryViewer_slam",
      "type": "trajectoryViewer",
      "label": "SLAM Trajectory (live)",
      "position": {
        "x": 1200,
        "y": 700
      },
      "config": {
        "axes": "auto",
        "align": "on",
        "max_points": "5000"
      }
    },
    {
      "id": "pyslam_get_traj",
      "type": "model_pyslam__get_trajectory",
      "label": "pySLAM: Get Trajectory",
      "position": {
        "x": 2040,
        "y": 100
      },
      "config": {}
    },
    {
      "id": "pyslam_get_map",
      "type": "model_pyslam__get_map",
      "label": "pySLAM: Get Map (final)",
      "position": {
        "x": 2040,
        "y": 340
      },
      "config": {
        "stream_every": "0"
      }
    },
    {
      "id": "pyslam_get_map_live",
      "type": "model_pyslam__get_map",
      "label": "pySLAM: Get Map (live, every 20)",
      "position": {
        "x": 1360,
        "y": 360
      },
      "config": {
        "stream_every": "20"
      }
    },
    {
      "id": "pyslam_eval",
      "type": "model_pyslam__eval_trajectory",
      "label": "pySLAM: Eval Trajectory (ATE / RPE)",
      "position": {
        "x": 2380,
        "y": 100
      },
      "config": {
        "is_monocular": "false"
      }
    },
    {
      "id": "pointCloudViewer_slam",
      "type": "pointCloudViewer",
      "label": "SLAM Map (3-D, live)",
      "position": {
        "x": 1780,
        "y": 700
      },
      "config": {
        "max_points": "30000",
        "point_size": "1.5"
      }
    },
    {
      "id": "output_port__slam_map_handle",
      "type": "graphOut",
      "label": "slam_map_handle",
      "position": {
        "x": 2700,
        "y": 340
      },
      "config": {
        "portName": "slam_map_handle",
        "wireType": "TEXT"
      }
    },
    {
      "id": "output_port__slam_eval_metrics",
      "type": "graphOut",
      "label": "slam_eval_metrics",
      "position": {
        "x": 2700,
        "y": 80
      },
      "config": {
        "portName": "slam_eval_metrics",
        "wireType": "TEXT"
      }
    }
  ],
